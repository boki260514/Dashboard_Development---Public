@echo off
REM ============================================================
REM  엑셀 트래커 감시 + 대시보드 자동 갱신
REM ============================================================
REM  이 파일을 더블클릭하면 백그라운드에서 엑셀 변경을 감시하고
REM  변경 감지 시 자동으로 대시보드를 갱신합니다.
REM ============================================================

REM 작업 디렉토리를 이 .bat 파일 위치로 설정
cd /d "%~dp0"

REM 콘솔창 제목 설정
title 대시보드 자동 감시

REM 최소화된 상태로 파이썬 스크립트 실행
REM (창은 작업표시줄에서 클릭하면 다시 열림)
start "대시보드 자동 감시" /min python "%~dp0watch_excel.py"

REM 시작 후 바로 종료 (감시 프로세스는 별도로 계속 실행됨)
exit
