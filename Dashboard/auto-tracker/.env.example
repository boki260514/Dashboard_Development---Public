# ============================================================
# 작업일보 자동화 환경설정
# ============================================================
# 이 파일을 .env 로 복사한 뒤 본인 값으로 채워 넣으세요.
# cp .env.example .env
#
# 주의: .env 파일은 공유하지 마세요. 비밀번호가 들어있습니다.

# --- 다우오피스 메일 계정 ---
EMAIL_ADDRESS=yoon01@hcnsservice.co.kr
EMAIL_PASSWORD=여기에_본인_비밀번호_입력

# --- IMAP (메일 수신용) ---
# 다우오피스 표준값. 회사 별도 설정이면 변경.
IMAP_HOST=imap.daouoffice.com
IMAP_PORT=993

# --- SMTP (미수신 알림 발송용) ---
SMTP_HOST=smtp.daouoffice.com
SMTP_PORT=465

# --- 작업일보 메일 식별 ---
# 허용 발신자(쉼표로 구분, 여러 명 가능)
ALLOWED_SENDERS=yujin8133@hcnsservice.co.kr,hongryul92@hcns.co.kr
# 제목 키워드 (이 문자열이 제목에 포함된 메일만 처리)
SUBJECT_KEYWORD=작업일보

# --- 미수신 알림 받을 주소 ---
ALERT_TO=yoon01@hcnsservice.co.kr

# --- Claude API (메일 분류용) ---
# https://console.anthropic.com/ 에서 발급. sk-ant-... 로 시작.
# 비워두면 모든 메일이 '검토필요'로 기록됩니다.
ANTHROPIC_API_KEY=
